# ============================================================
# CRISIS-BENCH Environment Configuration
# Copy to .env and fill in your values: cp .env.example .env
# ============================================================

# --- Chinese LLM APIs (all OpenAI-compatible) ---
DEEPSEEK_API_KEY=
QWEN_API_KEY=
KIMI_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=

# --- Indian Government APIs ---
BHUVAN_TOKEN=
NASA_FIRMS_KEY=
DATA_GOV_IN_KEY=

# --- Bhashini Translation (free govt API) ---
BHASHINI_USER_ID=
BHASHINI_ULCA_API_KEY=
BHASHINI_INFERENCE_API_KEY=

# --- Local Ollama ---
OLLAMA_HOST=http://localhost:11434

# --- Database Passwords ---
POSTGRES_PASSWORD=crisis_dev
NEO4J_PASSWORD=crisis_dev

# --- Service Ports (optional, override if defaults conflict) ---
# POSTGRES_PORT=5434
# REDIS_PORT=6381

# --- Langfuse (self-hosted LLM observability) ---
LANGFUSE_SECRET=crisis-bench-dev
LANGFUSE_SALT=crisis-bench-salt
