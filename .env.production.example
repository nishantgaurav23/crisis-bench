# ============================================================
# CRISIS-BENCH Production Environment Configuration
# Oracle Cloud Always Free (ARM64 Ampere A1)
#
# Copy to .env and fill in all values:
#   cp .env.production.example .env
# ============================================================

# --- Server ---
SERVER_DOMAIN=your-server-ip-or-domain

# --- Database Passwords (CHANGE THESE!) ---
POSTGRES_PASSWORD=
NEO4J_PASSWORD=
REDIS_PASSWORD=
GRAFANA_PASSWORD=

# --- Langfuse (self-hosted LLM observability) ---
LANGFUSE_SECRET=
LANGFUSE_SALT=

# --- Chinese LLM APIs (all OpenAI-compatible) ---
DEEPSEEK_API_KEY=
QWEN_API_KEY=
KIMI_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=

# --- Indian Government APIs ---
BHUVAN_TOKEN=
NASA_FIRMS_KEY=
DATA_GOV_IN_KEY=

# --- Bhashini Translation (free govt API) ---
BHASHINI_USER_ID=
BHASHINI_ULCA_API_KEY=
BHASHINI_INFERENCE_API_KEY=

# --- Local Ollama (runs on host, not Docker) ---
OLLAMA_HOST=http://host.docker.internal:11434
